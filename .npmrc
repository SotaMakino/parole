# Cloudflare Pages installs with npm (npm install), not bun. npm's strict peer
# resolution rejects the rescript-vitest x vite version range and fails the
# deploy with ERESOLVE. legacy-peer-deps restores the lenient behaviour bun
# already uses locally and in CI, so `npm install` succeeds on Cloudflare.
# Keep this at the repo root — npm ignores a .npmrc inside a workspace folder.
legacy-peer-deps=true
