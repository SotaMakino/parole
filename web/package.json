{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite",
    "res:build": "rescript",
    "res:watch": "rescript build -w",
    "build": "rescript && bunx --bun vite build",
    "test": "rescript && bunx --bun vitest run",
    "lint": "rescript format -check -all && rescript clean && rescript build",
    "preview": "bunx --bun vite preview",
    "format": "rescript format -all"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@rescript/react": "^0.13.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "happy-dom": "^20.10.6",
    "rescript": "^11.1.4",
    "rescript-vitest": "^2.1.1",
    "vite": "^8.1.1",
    "vitest": "^3"
  }
}
